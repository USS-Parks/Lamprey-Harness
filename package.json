{
  "name": "lamprey-harness",
  "version": "0.17.0",
  "description": "Multi-agent coding harness for DeepSeek V4 Pro/Flash, Gemma, Qwen, and GLM.",
  "main": "./out/main/index.js",
  "bin": {
    "lamprey": "./out/main/cli.js"
  },
  "author": {
    "name": "Basho Parks",
    "url": "https://github.com/USS-Parks/lamprey"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/USS-Parks/lamprey.git"
  },
  "homepage": "https://github.com/USS-Parks/lamprey",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:proof": "node scripts/verify-proof.cjs",
    "verify:all": "npm run build && node scripts/verify-proof.cjs --require-smokes",
    "smoke:bundle": "node scripts/smoke-bundle.cjs",
    "smoke:renderer": "node scripts/smoke-renderer.cjs",
    "lamprey": "electron-vite dev -- --lamprey-headless",
    "build:win": "electron-vite build && electron-builder --win --publish never",
    "build:mac": "electron-vite build && electron-builder --mac --publish never",
    "build:linux": "electron-vite build && electron-builder --linux --publish never",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "hooks:install": "git config core.hooksPath scripts/hooks"
  },
  "dependencies": {
    "@babel/standalone": "^7.29.7",
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "mammoth": "^1.12.0",
    "mermaid": "^11.16.0",
    "node-html-parser": "^7.1.0",
    "openai": "^6.45.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.0",
    "sqlite-vec": "^0.1.9",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.9",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-rebuild": "^3.2.9",
    "electron-updater": "^6.8.9",
    "electron-vite": "^5.0.0",
    "eslint": "^10.6.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.9.4",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
